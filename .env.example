# Copy to .env.local in repo root or export before running sync_sqlite_to_neon.py.
# Pull from Vercel after Neon is linked: vercel env pull .env.development.local
#
# Use unpooled URL for bulk sync (long-lived connection).
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# Pooled URL is fine for serverless / short queries later.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require
